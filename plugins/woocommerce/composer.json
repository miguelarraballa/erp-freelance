{
  "name": "contabilidad/woocommerce",
  "description": "Integración WooCommerce: importar pedidos como facturas simplificadas",
  "type": "library",
  "version": "1.0.0",
  "license": "proprietary",
  "require": {
    "php": "^8.1"
  },
  "autoload": {
    "psr-4": {
      "Woocommerce\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Woocommerce\\WoocommerceServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
